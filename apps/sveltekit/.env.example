# ── SiteSync Pro — Environment Variables ──
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local

# ── Convex (Required) ──
# Your Convex deployment URL. Get this from `npx convex dev` output or Convex dashboard.
VITE_CONVEX_URL=http://localhost:3210

# ── Better Auth (Required) ──
# Generate a strong random secret: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
# Public URL of your app (no trailing slash). Used for auth redirects.
BETTER_AUTH_URL=http://localhost:3000

# ── Production Convex URL (Optional, for production deployment) ──
# Overrides VITE_CONVEX_URL in production. Set this in your production env.
# CONVEX_URL=https://your-project.convex.cloud

# ── Feature Flags (Optional) ──
# PUBLIC_ENABLE_ANALYTICS=false
# PUBLIC_ENABLE_NOTIFICATIONS=true

# ── Monitoring (Optional) ──
# OTEL_SDK_DISABLED=true
