{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "outDir": "./dist"
  },
  "include": ["./**/*.ts"],
  "exclude": ["./_generated", "node_modules"]
}
